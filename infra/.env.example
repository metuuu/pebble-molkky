# Copy this file to `.env` and fill in real values. `.env` is gitignored — never
# commit it (this is a public repo).
#
#   cp .env.example .env
#
# After editing, `npm run put-secret` pushes the secret to AWS SSM, and
# `npm run deploy` reads the rest from here (no -c flags needed).

# --- From your GitHub OAuth App (Settings > Developer settings > OAuth Apps) ---
# Public client id — ends up in the Lambda env and the page; not sensitive, but
# kept here so nothing is hardcoded.
GITHUB_CLIENT_ID=

# The OAuth app client secret. SENSITIVE. Stored in AWS SSM (SecureString) by
# `npm run put-secret`; it is NOT baked into the deployed template/Lambda.
GITHUB_CLIENT_SECRET=

# --- Deploy config (defaults are fine for this project) -----------------------
# SSM parameter name the Lambda reads the secret from at runtime.
GITHUB_CLIENT_SECRET_PARAM=/molkky/github-oauth-client-secret

# CORS origin allowed to call the Function URL — your GitHub Pages origin.
ALLOW_ORIGIN=https://metuuu.github.io

# AWS account/region for the deploy (or rely on your usual AWS_PROFILE / CLI config).
# AWS_REGION=eu-north-1
